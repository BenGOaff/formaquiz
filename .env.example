# ─────────────────────────────────────────────────────────────────
# FormaQuiz — variables d'environnement
# En DEV local : copie ce fichier en .env.local
# Sur le VPS prod : les vars vivent dans .env (convention serveur Béné,
# cf. AGENTS.md Tiquiz). Source-le avec : set -a; . .env; set +a
# Ne jamais committer .env / .env.local (cf. .gitignore).
# ─────────────────────────────────────────────────────────────────

# Supabase (nouveau projet, séparé de Tiquiz/Tipote)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL publique de l'app (sous-domaine Cloudflare)
NEXT_PUBLIC_APP_URL=https://formaquiz.tipote.com

# Webhook Systeme.io (accès après achat)
# - SYSTEME_IO_WEBHOOK_SECRET : secret partagé dans l'URL du webhook (?secret=)
# - SYSTEME_IO_WEBHOOK_SIGNING_SECRET : si défini, on EXIGE la signature HMAC
SYSTEME_IO_WEBHOOK_SECRET=
SYSTEME_IO_WEBHOOK_SIGNING_SECRET=

# Coach IA (API Anthropic). Optionnel au MVP Jour 1.
ANTHROPIC_API_KEY=
# Override optionnel du modèle (sinon défaut centralisé dans lib/anthropicModel.ts)
ANTHROPIC_MODEL=

# Pipeline vidéo auto-hébergé (réutilise l'infra popquiz du VPS).
# Même serveur tus + nginx que Tiquiz, namespace applicatif "formaquiz".
# Le secret JWT DOIT être le même que celui du serveur tus (/opt/popquiz-tus).
POPQUIZ_TUS_JWT_SECRET=
# Base URL du serveur d'upload tus (ex: https://video.tipote.com/files)
FORMAQUIZ_TUS_ENDPOINT=
# Base URL de lecture nginx signée (ex: https://video.tipote.com/stream)
FORMAQUIZ_VIDEO_PLAYBACK_BASE=
# Secret nginx secure_link pour signer les URLs de lecture
FORMAQUIZ_VIDEO_SECURE_LINK_SECRET=
